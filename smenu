#!/bin/bash
# ZAW SLOWDNS (DNSTT) MANAGER - PREMIUM + AUTO CLEAN + KEY FIX

trap ' ' INT
set +e

B="\e[1;34m"; G="\e[1;32m"; Y="\e[1;33m"; R="\e[1;31m"; C="\e[1;36m"; Z="\e[0m"

IP=$(cat /etc/IP 2>/dev/null || wget -qO- ipv4.icanhazip.com 2>/dev/null)
NS_DOMAIN=$(cat /etc/slowdns/nsdomain 2>/dev/null || echo "No-NS-Domain")

# 🔴 FIX: Public Key ကို အမှားအယွင်းမရှိ သေချာဖတ်ပေးမည့် စနစ် 🔴
PUB_KEY=$(cat /etc/slowdns/server.pub 2>/dev/null | tr -d '\n\r')
if [[ -z "$PUB_KEY" ]]; then PUB_KEY="⚠️ Error-No-Key"; fi

# === 🔴 AUTO-CLEAN (အကောင့်အလိုလိုဖျက်) စနစ် 🔴 ===
clean_expired_users_silent() {
    local today_days=$(($(date +%s) / 86400))
    for user in $(awk -F: '$3 >= 1000 && $1 != "nobody" {print $1}' /etc/passwd); do
        exp_days=$(awk -F: -v u="$user" '$1 == u {print $8}' /etc/shadow)
        if [[ -n "$exp_days" && "$exp_days" =~ ^[0-9]+$ ]]; then
            if (( exp_days < today_days )); then
                userdel -f "$user" >/dev/null 2>&1
            fi
        fi
    done
}

header() {
    clear
    echo -e "           \033[38;5;226m███████████████████████████████\033[0m"
    echo -e "           \033[38;5;40m██████████████\033[1;37m ★ \033[38;5;40m██████████████\033[0m"
    echo -e "           \033[38;5;196m███████████████████████████████\033[0m"
    echo -e "           \033[38;5;208m█████████\033[1;37m S L O W D N S \033[38;5;208m█████████\033[0m\n"
    
    echo -e "\033[1;36m╭━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━╮\033[0m"
    echo -e "\033[1;36m┃ \033[1;33m🌐 NS Domain : \033[1;37m$NS_DOMAIN\033[0m"
    echo -e "\033[1;36m┃ \033[1;33m🔑 Pub Key   : \033[1;37m$PUB_KEY\033[0m"
    echo -e "\033[1;36m╰━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━╯\033[0m\n"
}

show_account_table() {
    local count=$(awk -F: '$3 >= 1000 && $1 != "nobody" {print $1}' /etc/passwd | wc -l)
    if [ "$count" -eq 0 ]; then echo -e "${R}  ⚠️ အကောင့်မရှိသေးပါ။${Z}"; return 1; fi

    echo -e "  ${C}╔════╦══════════════╦══════════════╦════════════╗${Z}"
    echo -e "  ${C}║ ${Y}စဉ်${C} ║ ${Y}အမည်${C}         ║ ${Y}ကုန်ဆုံးရက်${C}    ║ ${Y}အခြေအနေ${C}    ║${Z}"
    echo -e "  ${C}╠════╬══════════════╬══════════════╬════════════╣${Z}"

    local i=1
    local today_days=$(($(date +%s) / 86400))
    
    for user in $(awk -F: '$3 >= 1000 && $1 != "nobody" {print $1}' /etc/passwd); do
        exp_days=$(awk -F: -v u="$user" '$1 == u {print $8}' /etc/shadow)
        if [[ -z "$exp_days" || ! "$exp_days" =~ ^[0-9]+$ ]]; then continue; fi
        
        exp_date=$(date -d "1970-01-01 + $exp_days days" +"%Y-%m-%d" 2>/dev/null)
        
        if (( exp_days == today_days )); then
            printf "  ${C}║${Z} ${Y}%-2s${Z} ${C}║${Z} ${Y}%-12s${Z} ${C}║${Z} ${Y}%-12s${Z} ${C}║${Z} ${Y}⚠️ Today  ${C}║${Z}\n" "$i" "$user" "$exp_date"
        elif (( exp_days < today_days )); then
            printf "  ${C}║${Z} ${R}%-2s${Z} ${C}║${Z} ${R}%-12s${Z} ${C}║${Z} ${R}%-12s${Z} ${C}║${Z} ${R}❌ Expired${C}║${Z}\n" "$i" "$user" "$exp_date"
        else
            printf "  ${C}║${Z} %-2s ${C}║${Z} %-12s ${C}║${Z} %-12s ${C}║${Z} ${G}✅ Active ${C}║${Z}\n" "$i" "$user" "$exp_date"
        fi
        i=$((i+1))
    done
    echo -e "  ${C}╚════╩══════════════╩══════════════╩════════════╝${Z}"
    return 0
}

add_user() {
    clear
    echo -e "\E[44;1;37m         CREATE SLOWDNS ACCOUNT          \E[0m\n"
    read -p "◈ Username : " Login
    if [[ -z "$Login" ]]; then echo -e "${R}Error!${Z}"; sleep 1; return; fi
    if id "$Login" &>/dev/null; then echo -e "${R}ဤအမည်ရှိပြီးသားပါ။${Z}"; sleep 1; return; fi

    read -p "◈ Password : " Pass
    read -p "◈ Expire Days : " dias
    
    useradd -e $(date -d "+$dias days" +"%Y-%m-%d") -s /bin/false -M "$Login" >/dev/null 2>&1
    echo -e "$Login:$Pass" | chpasswd >/dev/null 2>&1
    
    exp=$(date -d "+$dias days" +"%Y-%m-%d")
    
    clear
    echo -e "\033[1;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
    echo -e "\033[1;32m🚀Thu Ya Zaw🚀 SlowDNS အကောင့်ဖန်တီးပြီးပါပြီ\033[0m"
    echo -e "\033[1;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
    echo -e "\033[1;33m◈📡 Host / IP  :⪧ \033[1;37m$IP\033[0m"
    echo -e "\033[1;33m◈🌐 NS Domain  :⪧ \033[1;37m$NS_DOMAIN\033[0m"
    echo -e "\033[1;33m◈🔑 Public Key :⪧ \033[1;37m$PUB_KEY\033[0m"
    echo -e "\033[1;33m◈🧸 Username   :⪧ \033[1;37m$Login\033[0m"
    echo -e "\033[1;33m◈🔏 Password   :⪧ \033[1;37m$Pass\033[0m"
    echo -e "\033[1;33m◈🕰 Expire Date:⪧ \033[1;37m$exp\033[0m"
    echo -e "\033[1;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
    read -n 1 -s -r -p "Press any key to return..."
}

del_user() {
    clear
    echo -e "\E[41;1;37m         DELETE SLOWDNS ACCOUNT          \E[0m\n"
    show_account_table || { read -n 1 -s -r -p "Press any key to return..."; return; }
    echo ""
    read -p "◈ Enter Username to Delete: " user
    if id "$user" &>/dev/null; then
        userdel -f "$user" >/dev/null 2>&1
        echo -e "\n${G}✅ Account $user deleted!${Z}"
    else
        echo -e "\n${R}❌ User not found!${Z}"
    fi
    read -n 1 -s -r -p "Press any key to return..."
}

renew_user() {
    clear
    echo -e "\E[42;1;37m       RENEW / EDIT SLOWDNS ACCOUNT      \E[0m\n"
    show_account_table || { read -n 1 -s -r -p "Press any key to return..."; return; }
    echo ""
    read -p "◈ Enter Username to Renew: " user
    if id "$user" &>/dev/null; then
        read -p "◈ တိုးလိုသော ရက်ပေါင်း ထည့်ပါ (ဥပမာ 30): " dias
        if [[ "$dias" =~ ^[0-9]+$ ]]; then
            chage -E $(date -d "+$dias days" +"%Y-%m-%d") "$user"
            echo -e "\n${G}✅ Account '$user' ကို ($dias) ရက် သက်တမ်းတိုးပြီးပါပြီ!${Z}"
        else
            echo -e "\n${R}❌ ရက်အရေအတွက် မှားယွင်းနေပါသည်။${Z}"
        fi
    else
        echo -e "\n${R}❌ User not found!${Z}"
    fi
    read -n 1 -s -r -p "Press any key to return..."
}

list_users() {
    clear
    echo -e "\E[44;1;37m               SLOWDNS ACCOUNT LIST            \E[0m\n"
    show_account_table
    echo ""
    read -n 1 -s -r -p "Press any key to return..."
}

while true; do
    clean_expired_users_silent
    header
    echo -e "\033[1;35m[\033[1;36m1\033[1;35m] \033[1;32m◈ \033[1;37mအကောင့်ဖန်တီးရန် (CREATE ACCOUNT)"
    echo -e "\033[1;35m[\033[1;36m2\033[1;35m] \033[1;32m◈ \033[1;37mအကောင့်ဖျက်ရန် (DELETE ACCOUNT)"
    echo -e "\033[1;35m[\033[1;36m3\033[1;35m] \033[1;32m◈ \033[1;37mသက်တမ်းတိုးရန် (RENEW ACCOUNT)"
    echo -e "\033[1;35m[\033[1;36m4\033[1;35m] \033[1;32m◈ \033[1;37mအကောင့်စာရင်းစစ်ရန် (LIST USERS)"
    echo -e "\033[1;35m[\033[1;36m0\033[1;35m] \033[1;32m◈ \033[1;31mထွက်မည် (EXIT)\033[0m"
    echo ""
    read -p "➔ ရွေးချယ်ရန်: " opt
    case $opt in
        1) add_user ;;
        2) del_user ;;
        3) renew_user ;;
        4) list_users ;;
        0) clear; exit 0 ;;
        *) echo "မှားယွင်းနေပါသည်။"; sleep 1 ;;
    esac
done
